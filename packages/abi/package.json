{
  "name": "@protokoll/abi",
  "version": "0.4.0",
  "description": "ABIs and deployment addresses for the protokoll EC-VRF contracts on Monad",
  "license": "MIT",
  "homepage": "https://docs.protokoll.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ericbsantana/protokoll.git",
    "directory": "packages/abi"
  },
  "keywords": [
    "protokoll",
    "vrf",
    "ec-vrf",
    "monad",
    "abi",
    "viem",
    "randomness"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "generate": "wagmi generate",
    "build": "tsc",
    "test": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@wagmi/cli": "^2.5.0",
    "typescript": "^6.0.3"
  }
}
