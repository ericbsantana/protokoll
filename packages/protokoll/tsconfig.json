{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022"],
		"types": ["node"],
		"outDir": "dist",
		"rootDir": ".",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"exactOptionalPropertyTypes": true,
		"skipLibCheck": true,
		"resolveJsonModule": true
	},
	"include": ["src/**/*", "src/scripts/**/*"],
	"exclude": ["node_modules", "dist", "out"]
}
